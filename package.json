{
  "name": "factos-ng",
  "version": "0.0.0",
  "scripts": {
    "prestart": "node ./scripts/generate-runtime-config.mjs",
    "ng": "ng",
    "start": "ng serve",
    "prebuild": "node ./scripts/generate-runtime-config.mjs",
    "build": "ng build --configuration production",
    "build:pwa": "ng build --configuration production && npx workbox generateSW",
    "prewatch": "node ./scripts/generate-runtime-config.mjs",
    "watch": "ng build --watch --configuration development",
    "pretest": "node ./scripts/generate-runtime-config.mjs",
    "test": "ng test --watch=false",
    "test:watch": "ng test",
    "test:facturar": "ng test --watch=false --include src/app/features/facturar/**/*.spec.ts",
    "prenetlify:build": "node ./scripts/generate-runtime-config.mjs",
    "netlify:build": "ng build --configuration production",
    "lint": "ng lint"
  },
  "prettier": {
    "printWidth": 100,
    "singleQuote": true,
    "overrides": [
      {
        "files": "*.html",
        "options": {
          "parser": "angular"
        }
      }
    ]
  },
  "engines": {
    "node": ">=20.19.0",
    "npm": ">=10.0.0"
  },
  "private": true,
  "dependencies": {
    "@angular/cdk": "^21.2.7",
    "@angular/common": "^21.2.9",
    "@angular/compiler": "^21.2.9",
    "@angular/core": "^21.2.9",
    "@angular/forms": "^21.2.9",
    "@angular/platform-browser": "^21.2.9",
    "@angular/router": "^21.2.9",
    "@angular/service-worker": "^21.2.9",
    "@supabase/supabase-js": "^2.106.2",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "date-fns": "^4.1.0",
    "pdfjs-dist": "^5.7.284",
    "pdfmake": "^0.3.9",
    "rxjs": "~7.8.0",
    "tailwind-merge": "^3.3.1",
    "tslib": "^2.3.0"
  },
  "devDependencies": {
    "@angular-eslint/builder": "^21.4.0",
    "@angular-eslint/eslint-plugin": "^21.4.0",
    "@angular-eslint/eslint-plugin-template": "^21.4.0",
    "@angular-eslint/schematics": "^21.4.0",
    "@angular-eslint/template-parser": "^21.4.0",
    "@angular/build": "^21.2.7",
    "@angular/cli": "^21.2.7",
    "@angular/compiler-cli": "^21.2.9",
    "@tailwindcss/forms": "^0.5.10",
    "@tailwindcss/postcss": "^4.1.12",
    "@tailwindcss/typography": "^0.5.16",
    "@types/pdfmake": "^0.3.2",
    "@typescript-eslint/eslint-plugin": "^8.58.2",
    "@typescript-eslint/parser": "^8.58.2",
    "autoprefixer": "^10.5.0",
    "eslint": "^9.39.4",
    "eslint-config-prettier": "^10.1.8",
    "jsdom": "^29.1.1",
    "postcss": "^8.5.10",
    "prettier": "^3.8.3",
    "supabase": "^2.101.0",
    "tailwindcss": "^4.3.0",
    "typescript": "~5.9.3",
    "vitest": "^4.1.7"
  }
}
